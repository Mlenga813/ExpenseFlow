generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-COMPANY SUPPORT
// ============================================

model Company {
  id          String   @id @default(cuid())
  name        String
  industry    String?
  logo        String?
  currency    String   @default("TZS")
  inviteCode  String   @unique @default(cuid())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  departments      Department[]
  requests         ExpenseRequest[]
  vehicleRequests  VehicleRequest[]
}

model Department {
  id        String   @id @default(cuid())
  name      String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id])
  users     User[]
  requests  ExpenseRequest[]
  vehicleRequests VehicleRequest[]
}

// ============================================
// USER MANAGEMENT WITH WORKFLOW ROLES
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String
  role         String   @default("EMPLOYEE") // EMPLOYEE, OPS_MANAGER, CHIEF_ACCOUNTANT, GENERAL_MANAGER, CASHIER, ADMIN, SUPER_ADMIN
  departmentId String?
  companyId    String
  isActive     Boolean  @default(true)
  signature    String?  // Base64 encoded signature image
  avatar       String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id])
  department       Department?       @relation(fields: [departmentId], references: [id])
  submittedRequests      ExpenseRequest[] @relation("SubmittedRequests")
  opsManagerReviews      ExpenseRequest[] @relation("OpsManagerReviews")
  chiefAccountantReviews ExpenseRequest[] @relation("ChiefAccountantReviews")
  generalManagerReviews  ExpenseRequest[] @relation("GeneralManagerReviews")
  cashierDisbursements   ExpenseRequest[] @relation("CashierDisbursements")
  approvalLogs     ApprovalLog[]
  notifications    Notification[]
  accounts         Account[]
  sessions         Session[]
  vehicleRequests  VehicleRequest[]  @relation("VehicleRequestor")
  vehicleOpsReviews VehicleRequest[] @relation("VehicleOpsManager")
  vehicleAcctReviews VehicleRequest[] @relation("VehicleChiefAccountant")
  vehicleGMReviews VehicleRequest[]  @relation("VehicleGeneralManager")
  vehicleApprovalLogs VehicleApprovalLog[]
}

// ============================================
// EXPENSE REQUEST / FUND REQUISITION
// ============================================

model ExpenseRequest {
  id                String   @id @default(cuid())
  requestNumber     String   @unique // Auto-generated: REQ-2026-0001
  title             String
  amount            Float
  category          String   // FUEL, PROJECT, TRAVEL, OFFICE_SUPPLIES, MAINTENANCE, TRAINING, OTHER
  description       String
  date              DateTime
  urgency           String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  accountCode       String?  // Budget line / account code
  vendorPayee       String?  // Vendor or payee name
  paymentMethod     String?  // CASH, BANK_TRANSFER, CHECK

  // Workflow status
  status            String   @default("PENDING_OPS_MANAGER")
  // PENDING_OPS_MANAGER -> PENDING_CHIEF_ACCOUNTANT -> PENDING_GENERAL_MANAGER -> PENDING_DISBURSEMENT -> DISBURSED -> REJECTED

  currentStep       Int      @default(1) // 1=OpsMgr, 2=ChiefAcct, 3=GM, 4=Cashier

  companyId         String
  requestedById     String
  departmentId      String?
  assignedOpsManagerId    String?
  assignedChiefAccountantId String?
  assignedGeneralManagerId   String?
  assignedCashierId        String?

  // Approval timestamps
  opsManagerApprovedAt      DateTime?
  chiefAccountantApprovedAt DateTime?
  generalManagerApprovedAt  DateTime?
  disbursedAt               DateTime?

  // Disbursement
  disbursementReference String?  // Cheque number, transaction ref, etc.
  disbursementNotes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company           Company        @relation(fields: [companyId], references: [id])
  requestedBy       User           @relation("SubmittedRequests", fields: [requestedById], references: [id])
  department        Department?    @relation(fields: [departmentId], references: [id])
  opsManager        User?          @relation("OpsManagerReviews", fields: [assignedOpsManagerId], references: [id])
  chiefAccountant   User?          @relation("ChiefAccountantReviews", fields: [assignedChiefAccountantId], references: [id])
  generalManager    User?          @relation("GeneralManagerReviews", fields: [assignedGeneralManagerId], references: [id])
  cashier           User?          @relation("CashierDisbursements", fields: [assignedCashierId], references: [id])

  attachments       Attachment[]
  approvalLogs      ApprovalLog[]
}


model Attachment {
  id               String   @id @default(cuid())
  filename         String
  originalName     String
  mimeType         String
  size             Int
  url              String
  expenseRequestId String
  createdAt        DateTime @default(now())

  expenseRequest   ExpenseRequest @relation(fields: [expenseRequestId], references: [id], onDelete: Cascade)
}

// ============================================
// APPROVAL WORKFLOW LOG
// ============================================

model ApprovalLog {
  id               String   @id @default(cuid())
  expenseRequestId String
  step             Int      // 1=OpsMgr, 2=ChiefAcct, 3=GM, 4=Cashier
  action           String   // SUBMITTED, APPROVED, REJECTED, INFO_REQUESTED, RESUBMITTED, DISBURSED, COMMENT
  comment          String?
  signature        String?  // Base64 signature at this step
  performedById    String
  createdAt        DateTime @default(now())

  expenseRequest   ExpenseRequest @relation(fields: [expenseRequestId], references: [id], onDelete: Cascade)
  performedBy      User           @relation(fields: [performedById], references: [id])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // SUBMISSION, APPROVAL, REJECTION, INFO_REQUEST, DISBURSEMENT, SYSTEM
  read      Boolean  @default(false)
  link      String?  // URL to related request
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// VEHICLE REQUEST (Kibali cha Gari)
// ============================================

model VehicleRequest {
  id                String   @id @default(cuid())
  requestNumber     String   @unique // Auto-generated: VEH-2026-0001

  // (A) Applicant Info
  requesterName     String   // Jina la Mwombaji
  department        String   // Idara
  position          String   // Cheo
  requestDate       DateTime @default(now()) // Tarehe

  // (B) Trip Details
  plateNumber       String   // Namba ya Gari
  reason            String   // Sababu ya matumizi ya gari
  departureTime     DateTime // Muda wa kuondoka
  destination       String   // Mahali gari linaenda
  boardMemberName   String?  // Mjumbe wa Bod / Mkuu wa Idara

  // (C) Vehicle Condition Before
  conditionBefore   String?  // Nzuri / Mbaya
  driverSignatureBefore String? // Sahihi ya dereva kabla

  // (D) Approval by Chairman/General Manager
  status            String   @default("PENDING_OPS_MANAGER")
  // PENDING_OPS_MANAGER -> PENDING_CHIEF_ACCOUNTANT -> PENDING_GENERAL_MANAGER -> APPROVED -> REJECTED
  currentStep       Int      @default(1) // 1=OpsMgr, 2=ChiefAcct, 3=GM

  companyId         String
  requestedById     String
  departmentId      String?
  assignedOpsManagerId      String?
  assignedChiefAccountantId String?
  assignedGeneralManagerId  String?

  // Approval timestamps
  opsManagerApprovedAt      DateTime?
  chiefAccountantApprovedAt DateTime?
  generalManagerApprovedAt  DateTime?

  // (E) Return Details
  returnTime        DateTime? // Muda wa kurudi
  returnDate        DateTime? // Tarehe ya kurudi
  conditionAfter    String?  // Nzuri / Mbaya
  driverSignatureAfter  String? // Sahihi ya dereva baada

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company           Company        @relation(fields: [companyId], references: [id])
  requestedBy       User           @relation("VehicleRequestor", fields: [requestedById], references: [id])
  department2       Department?    @relation(fields: [departmentId], references: [id])
  opsManager        User?          @relation("VehicleOpsManager", fields: [assignedOpsManagerId], references: [id])
  chiefAccountant   User?          @relation("VehicleChiefAccountant", fields: [assignedChiefAccountantId], references: [id])
  generalManager    User?          @relation("VehicleGeneralManager", fields: [assignedGeneralManagerId], references: [id])

  approvalLogs      VehicleApprovalLog[]
}

model VehicleApprovalLog {
  id                 String   @id @default(cuid())
  vehicleRequestId   String
  step               Int      // 1=OpsMgr, 2=ChiefAcct, 3=GM
  action             String   // SUBMITTED, APPROVED, REJECTED, INFO_REQUESTED
  comment            String?
  signature          String?  // Base64 signature
  performedById      String
  createdAt          DateTime @default(now())

  vehicleRequest     VehicleRequest @relation(fields: [vehicleRequestId], references: [id], onDelete: Cascade)
  performedBy        User           @relation(fields: [performedById], references: [id])
}

// ============================================
// SESSION (for NextAuth)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
